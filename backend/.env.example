# Copy to `.env` and fill in. `.env` is gitignored — keys never get committed.

# Groq (STT + LLM) — https://console.groq.com/keys
GROQ_API_KEY=

# Deepgram (TTS) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- STT provider ---
# STT_PROVIDER=deepgram          # or 'groq' (whisper) once your Groq project allows audio models

# --- optional overrides (defaults shown) ---
# PORT=8080
# HOST=0.0.0.0
# SAMPLE_RATE=16000
# STT_MODEL=nova-2               # Deepgram STT model
# GROQ_STT_MODEL=whisper-large-v3-turbo
# LLM_MODEL=llama-3.3-70b-versatile
# TTS_MODEL=aura-2-thalia-en
# MAX_TOKENS=160
# TIMEOUT_MS=20000
# SYSTEM_PROMPT=You are the voice of a desk macropad ...
